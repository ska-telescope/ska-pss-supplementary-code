<cheetah>
  <beams>
    <beam>
      <id>1</id>
      <active>true</active>
      <cpu>
        <affinity>0,1</affinity>
      </cpu>
      <sinks>
        <threads>2</threads>
        <channels>
          <raw>
            <active>true</active>
            <sink>
              <id>sigproc_file</id>
            </sink>
            <id>channel_raw</id>
          </raw>
        </channels>
        <sink_configs>
          <sigproc>
            <spectra_per_file>786432</spectra_per_file>
	    <dir>/tmp/beam1</dir>
            <extension>.fil</extension>
            <id>sigproc_file</id>
          </sigproc>
        </sink_configs>
      </sinks>
      <source>
        <udp_low>
          <number_of_threads>2</number_of_threads>
          <spectra_per_chunk>2048</spectra_per_chunk>
          <number_of_channels>7776</number_of_channels>
          <max_buffers>1</max_buffers>
          <listen>
            <port>34345</port>
            <ip_address>127.0.0.1</ip_address>
          </listen>
        </udp_low>
        <udp_low_lite>
          <number_of_threads>2</number_of_threads>
          <spectra_per_chunk>2048</spectra_per_chunk>
