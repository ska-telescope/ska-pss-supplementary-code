        </sink_configs>
      </sinks>
      <source>
        <udp_low>
          <number_of_threads>2</number_of_threads>
          <spectra_per_chunk>2048</spectra_per_chunk>
          <number_of_channels>7776</number_of_channels>
          <max_buffers>1</max_buffers>
          <listen>
            <port>34345</port>
            <ip_address>127.0.0.1</ip_address>
          </listen>
        </udp_low>
        <udp_low_lite>
          <number_of_threads>2</number_of_threads>
